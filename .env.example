鬠ｿ# Configuraﾃδｧﾃδｵes do Bot Telegram Student Agent
# IMPORTANTE: Copie este arquivo para .env e preencha com suas credenciais reais
# O arquivo .env nunca deve ser commitado no Git!

# Token do Bot do Telegram
# Obtenha em: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=seu_token_do_telegram_aqui

# Chave da API OpenAI
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_chave_openai_aqui

# URL do Ngrok para webhook (opcional)
# Atualize quando o ngrok mudar
NGROK_URL=https://seu-ngrok-url.ngrok-free.app

# Porta local para o webhook (opcional)
WEBHOOK_PORT=8080

# Credenciais do Mercado Pago (opcionais)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_mercadopago_aqui
MERCADOPAGO_PUBLIC_KEY=sua_public_key_mercadopago_aqui
